# Taster environment configuration.
# Copy to .env (local runs) or set these in docker-compose.yml.

# Port the HTTP server listens on.
PORT=3000

# Interface to bind. Keep 0.0.0.0 inside Docker.
HOST=0.0.0.0

# Directory holding runtime data: SQLite database and uploaded images.
# Mount this as a volume in Docker (/app/var).
DATA_DIR=./var

# REQUIRED for any run except `npm run dev`. Secret used to encrypt session
# cookies. Generate one with: openssl rand -base64 48
SESSION_SECRET=

# Public URL of the site (no trailing slash), e.g. https://tastes.example.com
# Used to build absolute URLs for OpenGraph previews, the Atom feed and the sitemap.
PUBLIC_URL=

# Set to 1 when the app is served over HTTPS (secure cookies).
COOKIE_SECURE=0

# Set to 1 when running behind a reverse proxy (Caddy, nginx, Traefik).
TRUST_PROXY=0

# Set to 1 to reset the admin account to taster/changeme on next boot, then remove it.
ADMIN_RESET=0

# Locale of the seeded categories and statuses on first boot: en or fr.
SEED_LOCALE=en

# Log verbosity: fatal, error, warn, info, debug, trace.
LOG_LEVEL=info
